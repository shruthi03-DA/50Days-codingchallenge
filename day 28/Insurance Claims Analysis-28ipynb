   "source": [
    "#Task 5: Risk Category Tagging\n",
    "risk_category = []\n",
    "for age in customer_age:\n",
    "    if age < 30:\n",
    "        risk_category.append(\"Low Risk\")\n",
    "    elif 30 <= age <= 45:\n",
    "        risk_category.append(\"Medium Risk\")\n",
    "    else:  # age > 45\n",
    "        risk_category.append(\"High Risk\")\n",
    "print(\"Risk Category:\", risk_category)"
   ]
