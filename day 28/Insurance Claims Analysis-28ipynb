      "Average Age of Approved Customers: 37.5\n"
     ]
    }
   ],
   "source": [
    "approved_age_total = 0\n",
    "approved_count = 0\n",
    "\n",
    "for i in range(len(claim_status)):\n",
    "    if claim_status[i] == \"Approved\":\n",
    "        approved_age_total += customer_age[i]\n",
    "        approved_count += 1\n",
    "\n",
    "average_age = approved_age_total / approved_count\n",
    "\n",
    "print(\"Average Age of Approved Customers:\", average_age)"
   ]
  },
